generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// TABEL BAWAAN DARI SUPABASE
// ==========================================

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  createdAt DateTime @default(now())
}

model bwm_best_others {
  id          BigInt   @default(autoincrement())
  code_member String   @id @db.VarChar
  created_at  DateTime @default(now()) @db.Timestamptz(6)
}

model bwm_other_worst {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

model calculate_bwm {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

model calculate_topsis {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

// SUDAH DIPERBAIKI: Menghapus @@ignore dan mengubah BigInt ke Int
model penilaian_kriteria {
  No                       Int     @id
  Destinasi_Kriteria       String? @map("Destinasi/Kriteria")
  Alam                     Int?
  Budaya                   Int?
  Edukasi                  Int?
  Sejarah                  Int?
  Petualangan              Int?
  Harga_Masuk              Int?    @map("Harga Masuk")
  Rating                   Int?
  Jarak                    Int?
  Kebersihan               Int?
  Pariwisata_Berkelanjutan Int?    @map("Pariwisata Berkelanjutan")
  Fasilitas_Umum           Int?    @map("Fasilitas Umum")
  Fasilitas_Penunjang      Int?    @map("Fasilitas Penunjang")
  Fasilitas_Disabilitas    Int?    @map("Fasilitas Disabilitas")
}

model user_data {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
}


// ==========================================
// TABEL BARU (SISTEM JOGJATRIP)
// ==========================================

// TABEL 1: PENGGUNA (Untuk Sistem Login/Register Ketua & Staff)
model User {
  id          String  @id @default(cuid())
  nama        String
  username    String  @unique
  password    String  
  role        String  // "KETUA" atau "STAFF"
  
  ruangDibuat Ruang[] 
}

// TABEL 2: RUANG (Untuk Generate Code Rombongan)
model Ruang {
  id          String   @id @default(cuid())
  kodeAkses   String   @unique
  status      String   @default("BUKA")
  
  pembuatId   String?
  pembuat     User?    @relation(fields: [pembuatId], references: [id])
  
  votes       Vote[]
  createdAt   DateTime @default(now())
}

// TABEL 3: VOTE (Untuk Hasil Voting Anggota MCDM)
model Vote {
  id          Int      @id @default(autoincrement())
  namaAnggota String
  
  umur        Int?     
  gender      String?  
  
  pilihan     String   
  
  ruangId     String
  ruang       Ruang    @relation(fields: [ruangId], references: [kodeAkses])
  
  waktuVote   DateTime @default(now())
}